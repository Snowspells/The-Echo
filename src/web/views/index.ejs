<%- include('partials/header', { title: 'Home', user }) %>

<div class="hero">
    <h1>The Echo</h1>
    <p class="hero-subtitle">The Echo Beckons. The Echo Nurtures. The Echo Watches.</p>
    <div class="hero-description">
        <p>Connect your Discord identity to the game world. Chat across dimensions. The Echo bridges all.</p>
    </div>
    <% if (!user) { %>
        <a href="/auth/login" class="btn btn-primary btn-lg">Login with Discord</a>
    <% } else { %>
        <a href="/dashboard" class="btn btn-primary btn-lg">Go to Dashboard</a>
    <% } %>
</div>

<div class="features">
    <div class="feature-card">
        <h3>Account Linking</h3>
        <p>Link your Discord account to your in-game identity. Track your marks, inventory, and progress all in one place.</p>
    </div>
    <div class="feature-card">
        <h3>Global Chat Bridge</h3>
        <p>Stay connected with the community whether you're in-game or on Discord. Messages flow seamlessly between both worlds.</p>
    </div>
    <div class="feature-card">
        <h3>Community Hub</h3>
        <p>A central place for the community &mdash; view your stats, manage your account, and stay in the loop.</p>
    </div>
</div>

<%- include('partials/footer') %>
