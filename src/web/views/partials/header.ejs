<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>The Echo</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-brand">
            <a href="/">The Echo</a>
        </div>
        <div class="nav-links">
            <a href="/">Home</a>
            <% if (user) { %>
                <a href="/dashboard">Dashboard</a>
                <% if (user.isStaff) { %>
                    <a href="/admin">Staff Panel</a>
                <% } %>
                <div class="nav-user">
                    <img src="<%= user.avatar
                        ? `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png?size=32`
                        : `https://cdn.discordapp.com/embed/avatars/${parseInt(user.id) % 5}.png` %>"
                        alt="avatar" class="nav-avatar">
                    <span><%= user.username %></span>
                    <a href="/auth/logout" class="btn btn-sm">Logout</a>
                </div>
            <% } else { %>
                <a href="/auth/login" class="btn btn-primary">Login with Discord</a>
            <% } %>
        </div>
    </nav>
    <main class="container">
