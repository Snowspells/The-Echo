<%- include('partials/header', { title: `Ticket #${ticket.id}`, user }) %>

<div class="ticket-detail">
    <div class="page-header">
        <h1>Ticket #<%= ticket.id %></h1>
        <span class="ticket-status ticket-<%= ticket.status %>"><%= ticket.status %></span>
    </div>

    <div class="ticket-info-grid">
        <div class="stat-card">
            <h3>Subject</h3>
            <p class="stat-value-sm"><%= ticket.subject %></p>
        </div>
        <div class="stat-card">
            <h3>Created By</h3>
            <p class="stat-value-sm"><%= ticket.creator_name %></p>
            <span class="stat-label"><%= ticket.creator_id %></span>
        </div>
        <div class="stat-card">
            <h3>Created</h3>
            <p class="stat-value-sm"><%= ticket.created_at ? new Date(ticket.created_at).toLocaleString() : 'N/A' %></p>
        </div>
        <% if (ticket.claimed_by_name) { %>
            <div class="stat-card">
                <h3>Claimed By</h3>
                <p class="stat-value-sm"><%= ticket.claimed_by_name %></p>
            </div>
        <% } %>
        <% if (ticket.closed_by_name) { %>
            <div class="stat-card">
                <h3>Closed By</h3>
                <p class="stat-value-sm"><%= ticket.closed_by_name %></p>
                <span class="stat-label"><%= ticket.closed_at ? new Date(ticket.closed_at).toLocaleString() : '' %></span>
            </div>
        <% } %>
        <% if (transcript) { %>
            <div class="stat-card">
                <h3>Messages</h3>
                <p class="stat-value-sm"><%= transcript.message_count %></p>
            </div>
        <% } %>
    </div>

    <% if (transcript) { %>
        <div class="transcript-section">
            <div class="transcript-header">
                <h2>Transcript</h2>
                <a href="/tickets/<%= ticket.id %>/transcript/raw" target="_blank" class="btn btn-sm btn-primary">Open Full Transcript</a>
            </div>
            <div class="transcript-embed">
                <iframe src="/tickets/<%= ticket.id %>/transcript/raw" frameborder="0" width="100%" height="600"></iframe>
            </div>
        </div>
    <% } else { %>
        <div class="empty-state">
            <p>No transcript available for this ticket<%= ticket.status === 'open' ? ' (ticket is still open)' : '' %>.</p>
        </div>
    <% } %>

    <div class="back-link">
        <a href="/tickets" class="btn">&larr; Back to Tickets</a>
    </div>
</div>

<%- include('partials/footer') %>
