<%- include('partials/header', { title: 'Global Chat', user }) %>

<div class="chat-page">
    <div class="chat-header">
        <div class="chat-title">
            <h1>Global Chat</h1>
            <span class="chat-subtitle">Bridged with Discord & In-Game Global</span>
        </div>
        <div class="chat-status">
            <span class="status-dot" id="statusDot"></span>
            <span id="statusText">Connecting...</span>
            <span class="online-count" id="onlineCount"></span>
        </div>
    </div>

    <% if (user.isStaff && user.staffLevel >= 2) { %>
    <div class="chat-mod-bar" id="modBar">
        <span class="mod-bar-label">Moderation</span>
        <button class="btn btn-sm" id="toggleMutes" onclick="toggleMutePanel()">Muted Users</button>
        <div class="mute-panel" id="mutePanel" style="display: none;">
            <div id="muteList"></div>
        </div>
    </div>
    <% } %>

    <div class="chat-container" id="chatContainer">
        <div class="chat-messages" id="chatMessages">
            <div class="chat-welcome">
                <p>Welcome to Global Chat. Messages here are bridged with Discord and the in-game Global channel.</p>
            </div>
        </div>
    </div>

    <div class="chat-input-area">
        <form id="chatForm" onsubmit="sendMessage(event)">
            <input type="text" id="chatInput" class="chat-input" placeholder="Type a message..." maxlength="500" autocomplete="off" />
            <button type="submit" class="btn btn-primary chat-send">Send</button>
        </form>
    </div>
</div>

<script>
    const currentUser = {
        id: '<%= user.id %>',
        username: '<%= user.username %>',
        isStaff: <%= user.isStaff ? 'true' : 'false' %>,
        staffLevel: <%= user.staffLevel || 0 %>
    };

    let ws;
    let reconnectTimer;
    let isMuted = false;

    function connectWebSocket() {
        const protocol = location.protocol === 'https:' ? 'wss:' : 'ws:';
        ws = new WebSocket(`${protocol}//${location.host}/ws/chat`);

        ws.onopen = () => {
            document.getElementById('statusDot').className = 'status-dot connected';
            document.getElementById('statusText').textContent = 'Connected';
            if (reconnectTimer) clearTimeout(reconnectTimer);
        };

        ws.onclose = () => {
            document.getElementById('statusDot').className = 'status-dot disconnected';
            document.getElementById('statusText').textContent = 'Disconnected';
            reconnectTimer = setTimeout(connectWebSocket, 3000);
        };

        ws.onerror = () => {
            document.getElementById('statusDot').className = 'status-dot disconnected';
            document.getElementById('statusText').textContent = 'Error';
        };

        ws.onmessage = (event) => {
            const data = JSON.parse(event.data);
            handleMessage(data);
        };
    }

    function handleMessage(data) {
        switch (data.type) {
            case 'history':
                data.messages.forEach(msg => appendMessage(msg));
                scrollToBottom();
                break;
            case 'message':
                appendMessage(data);
                scrollToBottom();
                break;
            case 'system':
                appendSystemMessage(data.content);
                scrollToBottom();
                break;
            case 'delete_message':
                removeMessage(data.messageId);
                break;
            case 'online_count':
                document.getElementById('onlineCount').textContent = `${data.count} online`;
                break;
            case 'muted':
                isMuted = true;
                document.getElementById('chatInput').disabled = true;
                document.getElementById('chatInput').placeholder = `Muted: ${data.reason}`;
                break;
            case 'unmuted':
                isMuted = false;
                document.getElementById('chatInput').disabled = false;
                document.getElementById('chatInput').placeholder = 'Type a message...';
                break;
            case 'error':
                appendSystemMessage(data.message);
                scrollToBottom();
                break;
        }
    }

    function appendMessage(msg) {
        const container = document.getElementById('chatMessages');
        const el = document.createElement('div');
        el.className = `chat-msg chat-msg-${msg.source || 'unknown'}`;
        if (msg.id) el.dataset.messageId = msg.id;

        const sourceLabel = { discord: 'Discord', game: 'Game', web: 'Web' }[msg.source] || msg.source;
        const time = msg.timestamp ? new Date(msg.timestamp).toLocaleTimeString() : '';

        let modActions = '';
        if (currentUser.isStaff && currentUser.staffLevel >= 2 && msg.author_id && msg.author_id !== currentUser.id) {
            modActions = `
                <span class="msg-mod-actions">
                    ${msg.id ? `<button class="msg-action-btn" onclick="deleteMessage(${msg.id})" title="Delete message">&#10005;</button>` : ''}
                    <button class="msg-action-btn" onclick="muteUser('${msg.author_id}', '${escapeHtml(msg.author_name)}')" title="Mute user">&#128263;</button>
                </span>`;
        }

        el.innerHTML = `
            <span class="msg-time">${time}</span>
            <span class="msg-source msg-source-${msg.source}">[${sourceLabel}]</span>
            <span class="msg-author">${escapeHtml(msg.author_name)}</span>
            <span class="msg-text">${escapeHtml(msg.content)}</span>
            ${modActions}
        `;

        container.appendChild(el);
    }

    function appendSystemMessage(text) {
        const container = document.getElementById('chatMessages');
        const el = document.createElement('div');
        el.className = 'chat-msg chat-msg-system';
        el.innerHTML = `<span class="msg-system-text">${escapeHtml(text)}</span>`;
        container.appendChild(el);
    }

    function removeMessage(messageId) {
        const el = document.querySelector(`[data-message-id="${messageId}"]`);
        if (el) {
            el.classList.add('msg-deleted');
            el.innerHTML = '<span class="msg-system-text">[Message deleted by staff]</span>';
        }
    }

    function sendMessage(e) {
        e.preventDefault();
        if (isMuted) return;
        const input = document.getElementById('chatInput');
        const content = input.value.trim();
        if (!content || !ws || ws.readyState !== WebSocket.OPEN) return;

        ws.send(JSON.stringify({ type: 'message', content }));
        input.value = '';
    }

    function deleteMessage(messageId) {
        if (!confirm('Delete this message?')) return;
        fetch('/chat/delete-message', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ messageId })
        });
    }

    function muteUser(userId, username) {
        const reason = prompt(`Mute ${username}? Enter reason (optional):`);
        if (reason === null) return;
        const duration = prompt('Mute duration in minutes (leave empty for permanent):');

        fetch('/chat/mute', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId, reason: reason || '', duration: duration || '' })
        });
    }

    function unmuteUser(userId) {
        fetch('/chat/unmute', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userId })
        });
        loadMutes();
    }

    function toggleMutePanel() {
        const panel = document.getElementById('mutePanel');
        if (panel.style.display === 'none') {
            panel.style.display = 'block';
            loadMutes();
        } else {
            panel.style.display = 'none';
        }
    }

    function loadMutes() {
        fetch('/chat/mutes').then(r => r.json()).then(data => {
            const list = document.getElementById('muteList');
            if (!data.mutes || data.mutes.length === 0) {
                list.innerHTML = '<p class="text-muted">No active mutes.</p>';
                return;
            }
            list.innerHTML = data.mutes.map(m => `
                <div class="mute-entry">
                    <span>${escapeHtml(m.user_id)}</span>
                    <span class="text-muted">${m.reason || 'No reason'}</span>
                    <span class="text-muted">${m.expires_at ? new Date(m.expires_at).toLocaleString() : 'Permanent'}</span>
                    <button class="btn btn-sm btn-danger" onclick="unmuteUser('${m.user_id}')">Unmute</button>
                </div>
            `).join('');
        });
    }

    function scrollToBottom() {
        const container = document.getElementById('chatContainer');
        container.scrollTop = container.scrollHeight;
    }

    function escapeHtml(str) {
        if (!str) return '';
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }

    connectWebSocket();
</script>

<%- include('partials/footer') %>
